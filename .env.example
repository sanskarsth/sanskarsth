# SECURITY: Environment Configuration Template
# DO NOT COMMIT .env.local or .env files with real values!
# Copy this file to .env.local and add your actual values
# NEVER include real credentials in version control

# API CONFIGURATION
GEMINI_API_KEY=your_gemini_api_key_here
APP_URL=http://localhost:3000

# SECURITY: Admin Credentials (for backend authentication)
# In production, use a proper database with hashed passwords
ADMIN_EMAIL_1=your_admin_email@example.com
ADMIN_PASSWORD_1=your_strong_password_here

# SESSION & JWT
JWT_SECRET=your_jwt_secret_key_change_this
SESSION_SECRET=your_session_secret_key_change_this

# DATABASE (if using backend)
DB_URL=your_database_url_here
DB_PASSWORD=your_database_password_here

# SECURITY: Feature Flags
NODE_ENV=development
ENABLE_RATE_LIMITING=true
ENABLE_INPUT_SANITIZATION=true
ENABLE_SECURITY_HEADERS=true

# LOGGING
LOG_LEVEL=info
SENTRY_DSN=your_sentry_dsn_for_error_tracking

# NOTES:
# - Change all values before production deployment
# - Use strong, unique passwords (12+ characters, mixed case, numbers, symbols)
# - Store sensitive values in secure vault (AWS Secrets Manager, etc.)
# - Rotate secrets regularly
# - Never share .env files or credentials via email/chat
